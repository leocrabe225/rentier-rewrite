{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(**)",
      "Task",
      "Glob",
      "Grep",
      "Bash(npm run test:run)",
      "Bash(npm run typecheck)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(rm:*)",
      "Bash(mv:*)"
    ]
  }
}
