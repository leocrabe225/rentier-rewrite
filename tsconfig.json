{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,

    "target": "ES2022",
    "lib": ["ES2022"],

    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
